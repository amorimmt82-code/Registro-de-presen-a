# ============================================================
# Configuração local (NÃO versionada — .env está no .gitignore)
# ============================================================

# Zoho Mail SMTP para o resumo diário de assiduidade.
# A conta atendimento@omelro.com está no data center EUROPEU (smtp.zoho.eu).
# Se tiver 2FA ativo, gere uma "App Password" no Zoho
# (Definições -> Segurança -> Passwords de aplicação) e use-a em SMTP_PASS.
# Confirme também que o acesso IMAP/SMTP está ativado na caixa de correio.
SMTP_HOST=smtp.zoho.eu
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=atendimento@omelro.com
SMTP_PASS=4ioup361R#

# Entrega do resumo diário.
DAILY_SUMMARY_ENABLED=true
DAILY_SUMMARY_TO=matheus.amorim@omelro.com
DAILY_SUMMARY_FROM=atendimento@omelro.com
DAILY_SUMMARY_CRON=0 18 * * 1-6
DAILY_SUMMARY_TIMEZONE=Europe/Lisbon
